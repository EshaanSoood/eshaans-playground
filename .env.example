# Vercel Environment Variables
# These should be set in Vercel dashboard or via vercel CLI

# External Payload CMS
PAYLOAD_CMS_URL=http://127.0.0.1:3001
CMS_WEBHOOK_SECRET=

# Main site URL (optional)
PUBLIC_MAIN_SITE_URL=https://eshaansood.in
NEXT_PUBLIC_BLOG_URL=https://dreamriver.eshaansood.in

# Listmonk campaign configuration
LISTMONK_BASE_URL=https://lists.eshaansood.org
LISTMONK_BLOG_LIST_ID=3
LISTMONK_FROM_EMAIL=Eshaan Sood <no-reply@eshaansood.org>

# Admin auth for campaign creation.
# Use one of:
# LISTMONK_API_CREDENTIALS=api_user:token
# or LISTMONK_API_USER + LISTMONK_API_TOKEN
LISTMONK_API_CREDENTIALS=
LISTMONK_API_USER=
LISTMONK_API_TOKEN=

# Webhook Secret (recommended for API security)
# Generate a random string for webhook authentication
# Set via: vercel env add WEBHOOK_SECRET production
WEBHOOK_SECRET=
